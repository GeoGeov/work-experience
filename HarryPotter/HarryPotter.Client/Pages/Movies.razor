@page "/movies"
@using HarryPotter.Client.Core.Models
@using HarryPotter.Client.Core.Services
@inject HarryPotterService HarryPotterService

<h1><b>Movies</b></h1>

<Addons>
	<Addon Class="addon-gap">
		<Dropdown>
			<DropdownToggle Color="Color.Primary ">Filter By</DropdownToggle>
			<DropdownMenu Class="px-4 py-3" Style="width:480px;">
				<div class="form-check">
					<input class="form-check-input" type="checkbox" id="byTitle" @bind="SearchByTitle" />
					<label class="form-check-label" for="byTitle">Title</label>
				</div>

@{
	<style scoped>
		.search-field {
			padding: 10px;
		}

		.addon-gap {
			margin-right: 32px;
		}
	</style>
}
				<div class="form-check mt-2">
					<input class="form-check-input" type="checkbox" id="bySynopsis" @bind="SearchBySynopsis" />
					<label class="form-check-label" for="bySynopsis">Synopsis</label>
				</div>
			</DropdownMenu>
		</Dropdown>
	</Addon>
	<Addon>
		<input class="form-control" placeholder="Search by title or synopsis" @bind="MovieSearchText" @bind:event="oninput" />
	</Addon>
</Addons>

<div class="movies-grid mt-3">
	@if (IsLoading)
	{
		<p>Loading...</p>
	}
	else if (MovieList?.Any() != true)
	{
		<p>No movies found.</p>
	}
	else
	{
		<div class="row">
			@foreach (Movie movie in FilteredMovies)
			{
				<div class="col-md-4 mb-3">
					<div class="card h-100">
						@if (!string.IsNullOrWhiteSpace(movie.Poster))
						{
							<img src="@movie.Poster" class="card-img-top" alt="@movie.Title" />
						}
						<div class="card-body">
							<h5 class="card-title">@movie.Title</h5>
							<p class="card-text">@movie.ReleaseDate</p>
							<p class="card-text">@movie.Synopsis</p>
						</div>
					</div>
				</div>
			}
		</div>
	}
</div>

@code {
	private List<Movie> MovieList { get; set; } = new List<Movie>();
	private string MovieSearchText { get; set; } = string.Empty;
	private bool IsLoading { get; set; }

	// Search filter toggles (ported from Spells.razor)
	private bool SearchByTitle { get; set; } = true;
	private bool SearchBySynopsis { get; set; } = true;

	protected override async Task OnInitializedAsync()
	{
		IsLoading = true;
		MovieList = await HarryPotterService.GetMoviesAsync();
		IsLoading = false;
	}

	private IEnumerable<Movie> FilteredMovies
	{
		get
		{
			if (string.IsNullOrWhiteSpace(MovieSearchText))
			{
				return MovieList;
			}

			return MovieList.Where(movie =>
			{
				var matchTitle = SearchByTitle && (movie.Title?.Contains(MovieSearchText, StringComparison.OrdinalIgnoreCase) ?? false);
				var matchSynopsis = SearchBySynopsis && (movie.Synopsis?.Contains(MovieSearchText, StringComparison.OrdinalIgnoreCase) ?? false);
				return matchTitle || matchSynopsis;
			});
		}
	}					 
}
