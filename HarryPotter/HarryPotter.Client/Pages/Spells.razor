@page "/spells"
@using Blazorise.LoadingIndicator
@using HarryPotter.Client.Core.Models
@using HarryPotter.Client.Core.Services
@inject HarryPotterService HarryPotterService

<h1><b>Spells</b></h1>



<div class="search-field">
    <Field Horizontal>
        <FieldBody ColumnSize="ColumnSize.Is2">
            @* Drop Down Menu*@
            <Dropdown Color="DropdownColor.Secondary">
                <DropdownToggle>Filter By</DropdownToggle>
                <DropdownMenu Class="px-4 py-3" Style="width:480px;">
                     @* Check Boxes connected to variables*@ 
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="byName" @bind="SearchByName" />
                        <label class="form-check-label" for="byName">Name</label>
                    </div>
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" id="byDescription" @bind="SearchByDescription" />
                        <label class="form-check-label" for="byDescription">Description</label>
                    </div>
                </DropdownMenu>
            </Dropdown>
        </FieldBody>
        <FieldBody ColumnSize="ColumnSize.Is4">
            <input class="form-control" placeholder="Search" @bind="SpellSearchText" @bind:event="oninput" />
        </FieldBody>
    </Field>
</div>

<table class="table table-striped table-hover spells-table">
    <thead>
        <tr>
            <th>Name</th>
                
            <th>Description</th>
        </tr>
    </thead>
    <tbody> 
        @if (IsLoading)
        {
            <tr>
                <td colspan="2"> <LoadingIndicator @bind-Visible="@IsLoading"></LoadingIndicator> </td>
            </tr>
        }

		@foreach (Spell spell in FilteredSpells)
		{
			<tr>
				<td>@spell.name</td>
				<td>@spell.description</td>
			</tr>
		}
    </tbody>
</table>

@{
    <style scoped>
        .search-field {
            padding: 10px;
        }

        .spells-table {
            margin-top: 10px;
        }
    </style>
}
@code {
    private string SpellSearchText = string.Empty;
    private List<Spell> SpellList { get; set; } = new List<Spell>();

    private bool SearchByName { get; set; } = true;
    private bool SearchByDescription { get; set; } = true;

    private bool IsLoading;
    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        SpellList = await HarryPotterService.GetSpellsAsync();
        IsLoading = false;
    }

    private IEnumerable<Spell> FilteredSpells
    {
        get
        {
            if (string.IsNullOrWhiteSpace(SpellSearchText))
            {
                return SpellList;
            }

            return SpellList.Where(spell =>
            {
                var matchName = SearchByName && (spell.name?.Contains(SpellSearchText, StringComparison.OrdinalIgnoreCase) ?? false);
                var matchDesc = SearchByDescription && (spell.description?.Contains(SpellSearchText, StringComparison.OrdinalIgnoreCase) ?? false);
                return matchName || matchDesc;
            });
        }
    }
}