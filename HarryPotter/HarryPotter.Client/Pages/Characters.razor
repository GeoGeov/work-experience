@page "/characters" 
@using Blazorise.LoadingIndicator
@using HarryPotter.Client.Core.Models
@using HarryPotter.Client.Core.Services
@inject HarryPotterService HarryPotterService

<h1><b>Characters</b></h1>
<Addons>
    <Addon>
         @* Drop Down Menu*@
            <Dropdown >
            <DropdownToggle Color="Color.Primary">Filter By</DropdownToggle>
                <DropdownMenu Class="px-4 py-3" Style="width:480px;">

                    <Addons>
                        <Addon Class="addon-gap">
                            <input class="form-check-input" type="checkbox" id="byHouse" @bind="SearchByHouse">
                        </Addon>
                        <Addon>
                            <Dropdown>
                                <DropdownToggle 
                                 Disabled="@(!SearchByHouse)"
                                 Color="@(SearchByHouse ? Color.Primary: Color.Secondary)"> 
                                    House 
                                </DropdownToggle>


                                <DropdownMenu Class="px-4 py-3" Style="width:480px;">
                                    <div class="form-check mt-2">
                                        <input class="form-check-input" type="checkbox" id="houseGryffindor" @bind="SearchGryffindor" />
                                        <label class="form-check-label" for="houseGryffindor">Gryffindor</label>
                                    </div>
                                    <div class="form-check mt-2">
                                        <input class="form-check-input" type="checkbox" id="houseSlytherin" @bind="SearchSlytherin" />
                                        <label class="form-check-label" for="houseSlytherin">Slytherin</label>
                                    </div>

                                    <div class="form-check mt-2">
                                        <input class="form-check-input" type="checkbox" id="houseRavenclaw" @bind="SearchRavenclaw" />
                                        <label class="form-check-label" for="houseRavenclaw">Ravenclaw</label>
                                    </div>
                                    <div class="form-check mt-2">
                                        <input class="form-check-input" type="checkbox" id="houseHufflepuff" @bind="SearchHufflepuff" />
                                        <label class="form-check-label" for="houseHufflepuff">Hufflepuff</label>
                                    </div>

                                </DropdownMenu>
                            </Dropdown>
                        </Addon>
                    </Addons>
                    
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" id="byStudents" @bind="SearchByStudents">
                        <label class="form-check-label" for="byStudents">Students</label>
                    </div>
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" id="byStaff" @bind="SearchByStaff">
                        <label class="form-check-label" for="byStaff">Staff</label>
                    </div>

                </DropdownMenu>
            </Dropdown>
    </Addon>
    <Addon>
        <AddonLabel> Search: </AddonLabel>
    </Addon>
    <Addon>
        <Select TValue="string" @bind-SelectedValue="@SearchType" Style="min-width:120px; max-width:160px">
            <option value="Name"> Name </option>
            <option value="Patronus"> Patronus </option>
            <option value="Ancestory"> Ancestory </option>
        </Select>
    </Addon>
    <Addon>
        <input class="form-control" placeholder="Search" @bind="CharacterSearchText" @bind:event="oninput" />
    </Addon>
</Addons>


<LoadingIndicator @bind-Visible="@IsLoading"></LoadingIndicator>

<div class="card-grid">
    @foreach (Character character in DisplayedCharacters)
    {
        <div class="card-border">
            <Card Style="@($"background-color: {GetHouseColor(character.House)}")">
                <div class="card-size">
                    <CardTitle Size="5" Class="card-title">
                        @character.Name
                    </CardTitle>
                    <CardImage Source="@GetImageSource(character.Image)"></CardImage>
                    <div class="card-body">
                        <CardBody>
                            <CardText>
                                <ListGroup>
                                    @if (!string.IsNullOrWhiteSpace(character.Gender))
                                    {
                                        <ListGroupItem><b>Gender:</b> @character.Gender</ListGroupItem>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(character.House))
                                    {
                                        <ListGroupItem><b>House:</b> @character.House</ListGroupItem>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(character.DateOfBirth))
                                    {
                                        <ListGroupItem><b>Date Of Birth:</b> @character.DateOfBirth</ListGroupItem>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(character.Ancestry))
                                    {
                                        <ListGroupItem><b>Ancestry:</b> @character.Ancestry</ListGroupItem>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(character.Patronus))
                                    {
                                        <ListGroupItem><b>Patronus:</b> @character.Patronus</ListGroupItem>
                                    }
                                    @if (HasWandDetails(character))
                                    {
                                        <ListGroupItem>
                                            <b>Wand:</b>
                                            <Button Class="read-more-button" @onclick="@(() => ToggleWandDetails(character))">
                                                @(character.ShowWandDetails ? "Hide details" : "Read more")
                                                <i class="arrow @(character.ShowWandDetails ? "up" : "down")"></i>
                                            </Button>
                                        </ListGroupItem>
                                    }
                                    @if (character.ShowWandDetails)
                                    {
                                        @if (!string.IsNullOrWhiteSpace(character.Wand?.Wood))
                                        {
                                            <ListGroupItem><b>Wood:</b> @character.Wand!.Wood</ListGroupItem>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(character.Wand?.Core))
                                        {
                                            <ListGroupItem><b>Core:</b> @character.Wand!.Core</ListGroupItem>
                                        }
                                        @if (character.Wand?.Length is not null)
                                        {
                                            <ListGroupItem><b>Length:</b> @character.Wand.Length</ListGroupItem>
                                        }
                                    }
                                </ListGroup>
                            </CardText>
                        </CardBody>
                    </div>
                </div>
            </Card>
        </div>
    }
</div>

@code {
    private const string DefaultImageUrl = "https://img.freepik.com/premium-vector/witch-s-broom-silhouette-isolated-white-background-traditional-halloween-decorative-element_502505-561.jpg";
    private string _characterSearchText = string.Empty;
    private string CharacterSearchText
    {
        get => _characterSearchText;
        set
        {
            if (_characterSearchText != value)
            {
                _characterSearchText = value;
                _ = UpdateFilteredCharactersAsync();
            }
        }
    }

    private bool IsLoading;

    private List<Character> CharacterList { get; set; } = new List<Character>();

    // Expose filter toggles as properties so changes trigger async filtering
    private bool _searchByHouse;
    private bool SearchByHouse
    {
        get => _searchByHouse;
        set { if (_searchByHouse != value) { _searchByHouse = value; _ = UpdateFilteredCharactersAsync(); } }
    }

    private bool _searchByStaff;
    private bool SearchByStaff
    {
        get => _searchByStaff;
        set { if (_searchByStaff != value) { _searchByStaff = value; _ = UpdateFilteredCharactersAsync(); } }
    }

    private bool _searchByStudents;
    private bool SearchByStudents
    {
        get => _searchByStudents;
        set { if (_searchByStudents != value) { _searchByStudents = value; _ = UpdateFilteredCharactersAsync(); } }
    }

    private bool _searchGryffindor, _searchSlytherin, _searchRavenclaw, _searchHufflepuff;
    private bool SearchGryffindor { get => _searchGryffindor; set { if (_searchGryffindor != value) { _searchGryffindor = value; _ = UpdateFilteredCharactersAsync(); } } }
    private bool SearchSlytherin { get => _searchSlytherin; set { if (_searchSlytherin != value) { _searchSlytherin = value; _ = UpdateFilteredCharactersAsync(); } } }
    private bool SearchRavenclaw { get => _searchRavenclaw; set { if (_searchRavenclaw != value) { _searchRavenclaw = value; _ = UpdateFilteredCharactersAsync(); } } }
    private bool SearchHufflepuff { get => _searchHufflepuff; set { if (_searchHufflepuff != value) { _searchHufflepuff = value; _ = UpdateFilteredCharactersAsync(); } } }

    private string _searchType = "Name";
    private string SearchType { get => _searchType; set { if (_searchType != value) { _searchType = value; _ = UpdateFilteredCharactersAsync(); } } }

    // Characters currently displayed after async filtering
    private IEnumerable<Character> DisplayedCharacters { get; set; } = new List<Character>();

    private CancellationTokenSource? _filterCts;

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        CharacterList = await HarryPotterService.GetCharactersAsync();
        // Initialize the displayed list asynchronously (will clear IsLoading when done)
        await UpdateFilteredCharactersAsync();
    }

    // There is almost certainly a more efficient way to do this.
    // Compute filtered characters synchronously; this will be invoked on a background thread
    private IEnumerable<Character> ApplyFilters()
    {
        // No search text: apply student/staff/house filters if specified
        if (string.IsNullOrWhiteSpace(CharacterSearchText))
        {
            IEnumerable<Character> result = CharacterList;
            if (SearchByStaff && !SearchByStudents)
            {
                result = result.Where(Character => Character.HogwartsStaff ?? false);
            }

            if (SearchByStudents && !SearchByStaff)
            {
                result = result.Where(Character => Character.HogwartsStudent ?? false);
            }

            // If house filtering is enabled and specific houses selected, apply house filter
            var anyHouseSelected = SearchGryffindor || SearchSlytherin || SearchRavenclaw || SearchHufflepuff;
            if (SearchByHouse && anyHouseSelected)
            {
                var selected = new List<string>();
                if (SearchGryffindor) selected.Add("Gryffindor");
                if (SearchSlytherin) selected.Add("Slytherin");
                if (SearchRavenclaw) selected.Add("Ravenclaw");
                if (SearchHufflepuff) selected.Add("Hufflepuff");

                result = result.Where(c => !string.IsNullOrWhiteSpace(c.House) && selected.Contains(c.House, StringComparer.OrdinalIgnoreCase));
            }

            // If both or neither are selected, result already contains all matching by house.
            return result;
        }

        // With search text: evaluate name/house text matches and optionally type filters
        return CharacterList.Where(Character =>
        {
            // Determine house match: if specific house checkboxes are selected, match by exact house membership;
            // otherwise use contains(text) to match house name.
            var anyHouseSelected = SearchGryffindor || SearchSlytherin || SearchRavenclaw || SearchHufflepuff;
            bool matchHouse;
            if (SearchByHouse && anyHouseSelected)
            {
                var selected = new List<string>();
                if (SearchGryffindor) selected.Add("Gryffindor");
                if (SearchSlytherin) selected.Add("Slytherin");
                if (SearchRavenclaw) selected.Add("Ravenclaw");
                if (SearchHufflepuff) selected.Add("Hufflepuff");

                matchHouse = !string.IsNullOrWhiteSpace(Character.House) && selected.Contains(Character.House, StringComparer.OrdinalIgnoreCase);
            }
            else
            {
                matchHouse = Character.House?.Contains(CharacterSearchText, StringComparison.OrdinalIgnoreCase) ?? false;
            }

            var matchStaff = Character.HogwartsStaff ?? false;
            var matchStudent = Character.HogwartsStudent ?? false;

            var matchName = Character.Name?.Contains(CharacterSearchText, StringComparison.OrdinalIgnoreCase) ?? false;
            var matchPatronus = Character.Patronus?.Contains(CharacterSearchText, StringComparison.OrdinalIgnoreCase) ?? false;
            var matchAncestory = Character.Ancestry?.Contains(CharacterSearchText, StringComparison.OrdinalIgnoreCase) ?? false;

            bool textMatch = false;
            if (SearchType == "Patronus")
            {
                textMatch = matchPatronus;
            }
            else if (SearchType == "Ancestory")
            {
                textMatch = matchAncestory;
            }
            else if (SearchType == "Name")
            {
                textMatch = matchName;
            }

            // Type filters (staff/student) if selected must match at least one; if none selected, allow both.
            var typeFilterSelected = SearchByStaff || SearchByStudents;
            bool typeMatch = typeFilterSelected
                ? ((SearchByStaff && matchStaff) || (SearchByStudents && matchStudent))
                : true;

            return textMatch && typeMatch && matchHouse;
        });
    }

    private async Task UpdateFilteredCharactersAsync()
    {
        // Cancel any in-flight update
        _filterCts?.Cancel();
        _filterCts = new CancellationTokenSource();
        var ct = _filterCts.Token;

        IsLoading = true;
        StateHasChanged();

        try
        {
            // Debounce a bit to coalesce rapid input changes and allow the loading indicator to render
            await Task.Delay(100, ct);

            // Run the potentially expensive filter on a background thread
            var results = await Task.Run(() => ApplyFilters().ToList(), ct);
            DisplayedCharacters = results;
        }
        catch (OperationCanceledException)
        {
            // ignore cancellations
            return;
        }
        finally
        {
            if (!ct.IsCancellationRequested)
            {
                IsLoading = false;
                StateHasChanged();
            }
        }
    }

    private Dictionary<string, string> HouseColors { get; set; } = new Dictionary<string, string>
    {
        {
            "Gryffindor", "#d49d9d"
        },
        {
            "Slytherin", "#a8d49b"
        },
        {
            "Ravenclaw", "#92a1d4"
        },
        {
            "Hufflepuff", "#edd69a"
        },
        {
            "", "#c7c7c7"
        }
    };
    private string GetImageSource(string? characterImage)
    {
        if (!string.IsNullOrWhiteSpace(characterImage))
        {
            return characterImage;
        }

        return DefaultImageUrl;
    }
    private string GetHouseColor(string? house)
    {
        string houseName = house ?? string.Empty;

        if (HouseColors.ContainsKey(houseName))
        {
            return HouseColors[houseName];
        }

        return HouseColors[string.Empty];
    }
    private static bool HasWandDetails(Character character)
    {
        bool hasWood = !string.IsNullOrWhiteSpace(character.Wand?.Wood);
        bool hasCore = !string.IsNullOrWhiteSpace(character.Wand?.Core);
        bool hasLength = character.Wand?.Length is not null;

        return hasWood || hasCore || hasLength;
    }
    private void ToggleWandDetails(Character character)
    {
        character.ShowWandDetails = !character.ShowWandDetails;
    }
}

@{
    <style scoped>
        .card-title {
            color: white;
            font-weight: bold;
        }

        .card-size {
            max-width: 200px;
            margin: 20px;
        }

        .card-grid {
            flex-flow: row wrap;
            margin-right: -.75rem;
            margin-left: -.75rem;
            display: flex;
        }

        .card-border {
            border: 5px solid #FFFFFF;
        }

        .card-body {
            padding-left: 0px !important;
            padding-right: 0px !important;
            padding-top: 10px !important;
        }

        .search-field {
            padding: 10px;
        }

        .read-more-button {
            padding: 0px !important;
            padding-right: 1px !important;
            background-color: transparent;
            background-repeat: no-repeat;
            border: none;
            cursor: pointer;
            overflow: hidden;
            outline: none;
        }

        .arrow {
            border: solid black;
            border-width: 0 2px 2px 0;
            display: inline-block;
            padding: 3px;
        }

        .down {
            transform: rotate(45deg);
            -webkit-transform: rotate(45deg);
            margin-bottom: 2px;
            margin-left: 5px;
        }

        .up {
            transform: rotate(-135deg);
            -webkit-transform: rotate(-135deg);
            margin-bottom: -1px;
            margin-left: 5px;
        }
    </style>
}